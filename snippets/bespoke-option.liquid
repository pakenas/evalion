{%- doc -%}
  Bespoke option — checkbox that flags order for bespoke consultation.
  Saved as line item property.
{%- enddoc -%}

<div class="bespoke-option" data-bespoke-option>
  <label class="bespoke-option__toggle">
    <input
      type="checkbox"
      name="properties[Bespoke]"
      value="Yes"
      data-bespoke-checkbox
    >
    <span class="bespoke-option__check"></span>
    <span class="bespoke-option__text">Bespoke</span>
  </label>
  <div class="bespoke-option__info" data-bespoke-info>
    <div class="bespoke-option__heading">Made to your specifications</div>
    <div class="bespoke-option__details">
      <div class="bespoke-option__detail">
        <span class="bespoke-option__detail-title">What's included</span>
        <span class="bespoke-option__detail-text">Personal consultation, custom measurements, hand-finished details and premium fabric selection</span>
      </div>
      <div class="bespoke-option__detail">
        <span class="bespoke-option__detail-title">Timeline</span>
        <span class="bespoke-option__detail-text">4–6 weeks from consultation to delivery</span>
      </div>
      <div class="bespoke-option__detail">
        <span class="bespoke-option__detail-title">How it works</span>
        <span class="bespoke-option__detail-text">Our team will contact you within 24 hours to arrange a fitting — in person or virtual</span>
      </div>
    </div>
  </div>
</div>

<style>
  .bespoke-option {
    padding: 16px 0;
    width: 100%;
  }

  .customisation-pickers {
    max-height: 500px;
    opacity: 1;
    overflow: hidden;
    transition: max-height 0.4s ease-in-out, opacity 0.3s ease-in-out;
  }

  .bespoke-option__toggle {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    font-size: 0.875rem;
    letter-spacing: 1.7px;
    text-transform: uppercase;
    font-weight: 400;
  }

  .bespoke-option__toggle input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .bespoke-option__check {
    width: 18px;
    height: 18px;
    border: 1px solid #000;
    flex-shrink: 0;
    position: relative;
    transition: background-color 0.15s;
  }

  .bespoke-option__toggle input:checked + .bespoke-option__check {
    background: #000;
  }

  .bespoke-option__toggle input:checked + .bespoke-option__check::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 2px;
    width: 5px;
    height: 9px;
    border: solid #fff;
    border-width: 0 1.5px 1.5px 0;
    transform: rotate(45deg);
  }

  .bespoke-option__info {
    display: none;
    padding: 14px 0 0 28px;
  }

  .bespoke-option__heading {
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 1.7px;
    text-transform: uppercase;
    margin-bottom: 14px;
    color: #000;
  }

  .bespoke-option__details {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .bespoke-option__detail {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .bespoke-option__detail-title {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #000;
  }

  .bespoke-option__detail-text {
    font-size: 0.8125rem;
    font-weight: 300;
    letter-spacing: 0.5px;
    line-height: 1.6;
    color: #666;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-bespoke-option]').forEach(function(el) {
      var checkbox = el.querySelector('[data-bespoke-checkbox]');
      var info = el.querySelector('[data-bespoke-info]');
      var pickers = el.parentElement.querySelector('[data-customisation-pickers]');

      checkbox.addEventListener('change', function() {
        if (this.checked) {
          info.style.display = 'block';
          if (pickers) {
            pickers.style.maxHeight = '0';
            pickers.style.opacity = '0';
            pickers.style.pointerEvents = 'none';
          }
        } else {
          info.style.display = 'none';
          if (pickers) {
            pickers.style.maxHeight = '500px';
            pickers.style.opacity = '1';
            pickers.style.pointerEvents = 'auto';
          }
        }
      });
    });
  });
</script>
