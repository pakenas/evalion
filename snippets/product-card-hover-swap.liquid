{%- doc -%}
  Anine Bing-style product card with hover image swap.
  Two images stacked, CSS visibility swap on hover. No JS.
{%- enddoc -%}

{% liquid
  assign first_image = product.featured_image
  assign second_image = nil

  if product.media.size > 1
    for media in product.media
      if media.preview_image != first_image and second_image == nil
        assign second_image = media.preview_image
      endif
    endfor
  endif

  assign img_sizes = sizes | default: '(min-width: 750px) 25vw, 50vw'
%}

<a href="{{ product.url }}" class="hover-swap" aria-label="{{ product.title }}">
  {% if first_image %}
    <img
      class="hover-swap__img hover-swap__img--primary"
      src="{{ first_image | image_url: width: 800 }}"
      srcset="{{ first_image | image_url: width: 400 }} 400w, {{ first_image | image_url: width: 600 }} 600w, {{ first_image | image_url: width: 800 }} 800w"
      sizes="{{ img_sizes }}"
      alt="{{ first_image.alt | escape }}"
      loading="lazy"
    >
    {% if second_image %}
      <img
        class="hover-swap__img hover-swap__img--secondary"
        src="{{ second_image | image_url: width: 800 }}"
        srcset="{{ second_image | image_url: width: 400 }} 400w, {{ second_image | image_url: width: 600 }} 600w, {{ second_image | image_url: width: 800 }} 800w"
        sizes="{{ img_sizes }}"
        alt="{{ second_image.alt | escape }}"
        loading="lazy"
      >
    {% endif %}
  {% else %}
    {{ 'product-apparel-1' | placeholder_svg_tag: 'hover-swap__placeholder' }}
  {% endif %}
</a>
