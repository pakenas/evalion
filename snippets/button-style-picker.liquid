{%- doc -%}
  Button style picker — reads custom.button_styles metafield (list).
  Renders image swatches, customer picks one.
  Images mapped by: value handleized + "_button.png" in shop files.
  Selection saved as line item property.
{%- enddoc -%}

{% liquid
  assign product = product | default: closest.product
  assign button_styles = product.metafields.custom.button_styles.value
%}

{% if button_styles and button_styles.size > 0 %}
  <div class="button-style-picker" data-button-style-picker>
    <div class="button-style-picker__label">
      <span class="button-style-picker__title">Button Style:</span>
      <span class="button-style-picker__selected" data-selected-style>{{ button_styles[0] }}</span>
    </div>
    <div class="button-style-picker__options">
      {% for style in button_styles %}
        {% assign style_handle = style | handleize | replace: '-', '_' %}
        {% assign swatch_file = style_handle | append: '_button.png' %}
        <label class="button-style-picker__option{% if forloop.first %} active{% endif %}" title="{{ style }}">
          <input
            type="radio"
            name="properties[Button Style]"
            value="{{ style }}"
            {% if forloop.first %}checked{% endif %}
          >
          <span class="button-style-picker__swatch">
            <img
              src="{{ swatch_file | file_url }}"
              alt="{{ style }}"
              width="40"
              height="40"
              loading="lazy"
            >
          </span>
          <span class="button-style-picker__name">{{ style }}</span>
        </label>
      {% endfor %}
    </div>
  </div>

  <style>
    .button-style-picker {
      width: 100%;
      padding: 16px 0;
    }

    .button-style-picker__label {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 12px;
      font-size: 0.875rem;
      letter-spacing: 1.7px;
      text-transform: uppercase;
    }

    .button-style-picker__title {
      font-weight: 400;
    }

    .button-style-picker__selected {
      font-weight: 300;
      text-transform: capitalize;
    }

    .button-style-picker__options {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .button-style-picker__option {
      position: relative;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
    }

    .button-style-picker__option input {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
    }

    .button-style-picker__swatch {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      border: 2px solid transparent;
      overflow: hidden;
      transition: border-color 0.15s;
    }

    .button-style-picker__swatch img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 50%;
    }

    .button-style-picker__option input:checked ~ .button-style-picker__swatch {
      border-color: #000;
    }

    .button-style-picker__option:hover .button-style-picker__swatch {
      border-color: #999;
    }

    .button-style-picker__option input:checked ~ .button-style-picker__swatch {
      border-color: #000;
    }

    .button-style-picker__name {
      font-size: 11px;
      letter-spacing: 0.5px;
      color: #666;
      text-transform: capitalize;
    }

    .button-style-picker__option input:checked ~ .button-style-picker__name {
      color: #000;
      font-weight: 500;
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[data-button-style-picker]').forEach(function(picker) {
        var radios = picker.querySelectorAll('input[type="radio"]');
        var selectedLabel = picker.querySelector('[data-selected-style]');
        var options = picker.querySelectorAll('.button-style-picker__option');

        radios.forEach(function(radio) {
          radio.addEventListener('change', function() {
            selectedLabel.textContent = this.value;
            options.forEach(function(opt) { opt.classList.remove('active'); });
            this.closest('.button-style-picker__option').classList.add('active');
          });
        });
      });
    });
  </script>
{% endif %}
