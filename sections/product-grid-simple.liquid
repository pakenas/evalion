{% liquid
  assign collection = section.settings.collection
  assign max_products = section.settings.max_products
  assign columns = section.settings.columns
  assign mobile_columns = section.settings.mobile_columns
  assign gap = section.settings.gap
%}

<style>
  .product-grid-simple {
    display: grid !important;
    grid-template-columns: repeat({{ columns }}, 1fr) !important;
    gap: {{ gap }}px;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    width: 100%;
  }

  @media screen and (max-width: 768px) {
    .product-grid-simple {
      grid-template-columns: repeat({{ mobile_columns }}, 1fr) !important;
    }
  }

  .product-grid-simple .hover-swap {
    padding-top: 0;
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #f4f4f4;
    display: block;
  }

  .product-grid-simple .hover-swap__img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-grid-simple .hover-swap__img--secondary {
    z-index: 2;
    visibility: hidden;
    transition: visibility 0s 0.5s;
  }

  @media (hover: hover) {
    .product-grid-simple .hover-swap:hover .hover-swap__img--secondary {
      visibility: visible;
      transition: visibility 0s 0s;
    }
  }

  .product-grid-simple .hover-swap__placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
</style>

<div class="product-grid-simple color-{{ section.settings.color_scheme }}">
  {% if collection != blank %}
    {% for product in collection.products limit: max_products %}
      {% render 'product-card-hover-swap', product: product, image_ratio: section.settings.image_ratio %}
    {% endfor %}
  {% else %}
    {% for i in (1..max_products) %}
      <div class="hover-swap" style="aspect-ratio: 4/5; background: #f4f4f4;">
        {% assign variant = i | modulo: 3 | plus: 1 %}
        {{ 'product-apparel-' | append: variant | placeholder_svg_tag: 'hover-swap__placeholder' }}
      </div>
    {% endfor %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Product Grid (Simple)",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "adapt", "label": "Auto" },
        { "value": "portrait", "label": "Portrait (4:5)" },
        { "value": "square", "label": "Square" },
        { "value": "landscape", "label": "Landscape (16:9)" }
      ],
      "default": "portrait"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "full-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "primary"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Product Grid (Simple)"
    }
  ]
}
{% endschema %}
